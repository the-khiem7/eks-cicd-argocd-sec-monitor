# HAProxy generated config file mounted by Docker Compose.
HAPROXY_CONFIG=generated/haproxy.cfg
HAPROXY_CONTAINER_NAME=haproxy-alb

# Host ports published by Docker Compose.
HAPROXY_HTTP_PORT=80
HAPROXY_HTTPS_PORT=443

# Optional HTTPS certificate path inside the HAProxy container.
# Leave empty to run HTTP only. Use this value when certs/<domain>.pem exists.
# HAPROXY_TLS_CERT=/usr/local/etc/haproxy/certs/benhvien.teamdevops.shop.pem

# Consul and Consul Template runtime settings.
CONSUL_IMAGE=hashicorp/consul:1.19
CONSUL_TEMPLATE_IMAGE=hashicorp/consul-template:latest
CONSUL_CONTAINER_NAME=haproxy-consul
CONSUL_TEMPLATE_CONTAINER_NAME=haproxy-consul-template
CONSUL_HTTP_PORT=127.0.0.1:8500

# Kubernetes node auto-discovery settings.
K8S_DISCOVERY_CONTAINER_NAME=haproxy-k8s-discovery
K8S_DISCOVERY_IMAGE=alpine/k8s:1.30.14
KUBECONFIG_PATH=./kubeconfig/config
SERVICE_NAME=traefik-nodeport
TRAEFIK_NODEPORT=30080
NODE_ADDRESS_TYPE=InternalIP
DISCOVERY_INTERVAL_SECONDS=15
CONSUL_DEREGISTER_CRITICAL_AFTER=1m
