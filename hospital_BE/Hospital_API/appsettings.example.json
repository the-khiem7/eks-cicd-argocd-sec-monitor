{
  "ConnectionStrings": {
    "DefaultConnection": "Server=<DB_HOST>,1433;Database=<DB_NAME>;User Id=<DB_USER>;Password=<DB_PASSWORD>;TrustServerCertificate=False;Encrypt=True",
    "Redis": "redis-primary.hospital-prod.svc.cluster.local:6379,password=<REDIS_PASSWORD>,abortConnect=false"
  },
  "Jwt": {
    "Secret": "<JWT_SECRET_KEY>",
    "Issuer": "HospitalAPI",
    "Audience": "HospitalClient"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
